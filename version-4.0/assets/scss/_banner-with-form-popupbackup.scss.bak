.banner-with-form {
  background: $gradient-bg;
  position: relative;
  .breadcrumbs {
    font-weight: 400;
    margin: 0 0 5px;
    &.service-breadcrumbs {
      color: $white;
    }
    a {
      color: rgba(255, 255, 255, 0.5);
      &:after {
        background: url(../../assets/images/breadcrumbs-arrow2.png) 0 1px
          no-repeat;
        background-size: 100%;
        opacity: 0.6;
      }
      &:hover {
        color: $white;
      }
    }
  }
  .dis-flex {
    padding: 40px 0 0;
    .hire-content {
      width: 46%;
      position: relative;
      h1 {
        color: $white;
        margin: 0 0 20px;
      }
      h2 {
        font-weight: 500;
        font-family: "Lexend Deca";
        font-size: 18px;
        color: $white;
        margin: 0 0 20px;
        line-height: 1.3;
      }

      p {
        color: rgba(255, 255, 255, 0.8);
        font-size: 18px;
        margin: 0 0 15px;
        line-height: 29px;

        &.white-txt {
          color: $white;
        }
      }
      span {
        color: rgba(255, 255, 255, 0.8);
      }
      ul {
        li {
          color: rgba(255, 255, 255, 0.8);
          font-weight: 400;
          font-size: 18px;
          position: relative;
          margin: 0 0 12px;
          padding-left: 20px;
          &:before {
            content: "";
            position: absolute;
            left: 0;
            top: 8px;
            width: 8px;
            height: 8px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 50%;
          }
        }
      }
    }

    .hire-form {
      position: relative;
      flex-basis: 38%;
      border-radius: 30px;

      &:before {
        content: "";
        display: block;
        background: url(../images/hire-shape.png) top center no-repeat;
        background-size: 100%;
        width: 138px;
        height: 150px;
        position: absolute;
        top: 80px;
        left: -221px;
      }

      .form-wrap {
        border-radius: 0 0 30px 30px;

        position: relative;
        z-index: 9;

        .top-sec {
          height: 200px;
          background: #201481;
          border-radius: 30px 30px 0 0;
          position: relative;

          &:before {
            content: "";
            background: url(../images/shape-bg.png) no-repeat center;
            width: 494px;
            height: 202px;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            margin: 0 auto;
            background-size: 100%;
          }

          img {
            margin-top: -60px;
            height: 260px;
          }
        }

        .top-update{
          
    height: 100px;
    background: #201481;
    border-radius: 30px 30px 0 0;
    position: relative;

          &:before {
            content: "";
            background: url(../images/shape-bg.png) no-repeat center;
            width: 494px;
            height: 202px;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            margin: 0 auto;
            background-size: 100%;
          }

          img {
            margin-top: -60px;
            height: 160px;
          }
        }

        

        .mid-sec {
          border-radius: 0 0 15px 15px;
          background: $white;
          .head-sec{padding:20px 25px 0;}
          .form-visible{display:block; padding:0 25px; position: relative;  background-color: #fff;
            &:before{content:''; background:rgba(224, 237, 255, 1);  position:absolute; z-index: 9; width:100%; left:0; top:0; height: 1px;}
              .popup-content{ background-color: #fff; width: inherit;     padding: 0;
                .banner-form-section {
                  .banner-form-outer{padding: 0;
                      .dis-flex{padding: 0;}
                      label{    opacity: 0.8;
                        color: #414141;
                        font-size: 14px;
                        font-weight: 500;
                        text-align: left;
                        display: block; margin:0 0 8px;}
                      input{ border:1px solid rgba(65, 65, 65, 0.5); color: #010101; height: 45px; font-size: 14px;}
                  }
                  .width-full{
                    .user-input{ border:1px solid rgba(65, 65, 65, 0.5);}
                  } 
                  .drop-box textarea{font-size: 14px;  color: #414141; height: 40px;}
                }
              }
            
          }
          .button-section {
            display: flex;
            align-items: baseline;
            position: relative;
            flex-wrap: wrap;
            padding:30px 25px;
            justify-content: center;

            .btn-div {
              .white-btn {
                background: $royelblue;
                border: 1px solid $royelblue;
                min-width: 200px;
                text-transform: capitalize;
                font-size: 16px;
                &:hover {
                  background: #fff;
                  color: $royelblue;
                }
              }
            }

            .info-wrap {
              margin: 8px 0 0;
              P {
                color: $arsenic-dark;
                line-height: 1.3;
                opacity: 0.7;
                font-size: 13px;
              }
            }

            .devide {
              padding: 0 10px;
              display: inline-block;
              position: relative;
              color: $arsenic-dark;
              opacity: 0.3;
              font-size: 12px;
              &:before {
                content: "";
                clear: both;
                display: block;
                width: 1px;
                height: 16px;
                position: absolute;
                background: $arsenic-dark;
                top: -20px;
                left: 19px;
              }
              &:after {
                content: "";
                clear: both;
                display: block;
                width: 1px;
                height: 16px;
                background: $arsenic-dark;
                position: absolute;
                bottom: -20px;
                left: 19px;
              }
            }

            .free-con {
              color: $arsenic-dark;
              font-size: 16px;

              a {
                color: #414141;
                opacity: 0.5;
                text-decoration: underline;
              }
            }
          }
        }

        ::placeholder {
          color: rgba(65, 65, 65, 0.52);
        }


        

        h3 {
          font-weight: 600;
          color: $arsenic-dark;
          font-size: 28px;
          line-height: 45px;
        }

        p {
          font-size: 18px;
          color: $arsenic-light;
        }

        .bottom-sec {
          padding: 20px 30px;
          border-top: 3px solid #e2edfa;
          background: $white;
          border-radius: 0 0 30px 30px;

          .use-form {
            display: block;

            color: $arsenic-dark;
            font-size: 14px;
            font-weight: 400;
            text-decoration: none;
            &:hover {
              text-decoration: underline;
            }
          }

          .frm-list {
            position: relative;
            margin: 15px 0 0;

            ul {
              display: flex;
              justify-content: center;
              li {
                position: relative;
                padding: 0 22px;
                font-size: 12px;
                margin: 0 7px;
                color: $arsenic-dark;
                line-height: 1.2;
                border-right: 1px solid $arsenic-dark;
                &:last-child {
                  border: 0;
                }

                &:before {
                  content: "";
                  clear: both;
                  display: block;
                  background: url(../images/list-check.png) top center no-repeat;
                  background-size: auto;
                  background-size: 100%;
                  width: 13px;
                  height: 13px;
                  position: absolute;
                  top: 1px;
                  left: 0;
                }

                &:after {
                  width: calc(100% - 40px);
                  content: "";
                  border-top: 1px dashed #666666;
                  height: 1px;
                  position: absolute;
                  bottom: -3px;
                  left: 20px;
                }

                &.process {
                  position: relative;
                  &:before {
                    background: url(../images/pro-icon.png) top center no-repeat;
                    width: 13px;
                    background-size: 100%;
                  }
                  .info {
                    width: 315px;
                    background: #eaf2ff;
                    border-radius: 10px;
                    padding: 15px;
                    position: absolute;
                    box-shadow: 0px 4px 35px rgba(227, 233, 245, 0.5);
                    bottom: -143px;
                    right: -40px;
                    opacity: 0;
                    transition: all 0.3s ease-in-out;
                    visibility: hidden;
                    h4 {
                      font-weight: 500;
                      font-size: 14px;
                      color: $black;
                      margin: 0 0 5px;
                      position: relative;
                      &:before {
                        content: "";
                        clear: both;
                        display: block;
                        background: url(../images/ex-arrow.png) top center
                          no-repeat;
                        background-size: auto;
                        background-size: 100%;
                        width: 25px;
                        height: 25px;
                        position: absolute;
                        top: -31px;
                        right: 30px;
                      }
                    }
                    p {
                      font-size: 10px;
                      line-height: 26px;
                      color: $black;
                      line-height: 16px;
                      margin: 0;
                    }
                  }
                  &:hover {
                    cursor: pointer;
                    color: #016be3;
                    .info {
                      opacity: 1;
                      visibility: visible;
                    }
                  }
                }

                &.list {
                  &:before {
                    background: url(../images/pro-icon2.png) top center
                      no-repeat;
                    width: 13px;
                    background-size: 100%;
                  }
                }
                &:first-child {
                  .info {
                    right: auto;
                    left: 0;
                  }
                }
              }
            }
          }
        }
      }

      .info-wrap {
        display: flex;
        justify-content: center;
        align-items: center;
        p {
          margin: 0;
        }
        .info {
          margin-left: 10px;
          display: inline-block;
          position: relative;
          cursor: pointer;
          &:after {
            content: "";
            width: 14px;
            height: 15px;
            background: url(../images/info-icon.svg) 0 0 no-repeat;
            position: absolute;
            top: 0;
            transform: translateY(-50%);
            left: 0;
          }

          .info-content {
            width: 315px;
            border-radius: 10px;
            background: #eaf2ff;
            box-shadow: 0px 4px 35px rgba(227, 233, 245, 0.5);

            padding: 15px;
            position: absolute;

            top: 20px;
            left: -75px;
            opacity: 0;
            transition: all 0.3s ease-in-out;
            visibility: hidden;
            text-align: left;
            line-height: initial;
            z-index: 9;
            h4 {
              font-size: 14px;
              color: $black;
              margin: 0 0 5px;
            }
            p {
              font-size: 11px;
              color: $black;
              line-height: 160%;
              margin: 0 0 5px;
              font-weight: normal;
            }

            .kmore {
              font-size: 11px;
              margin: 10px 0 0;
              text-decoration: underline;
              position: relative;
              color: $black;
              &:after {
                content: "";
                background: url(../images/know-arrow.png) 0 0 no-repeat;
                width: 8px;
                display: inline-block;
                height: 8px;
                margin-left: 5px;
                transition: all 0.3s ease-in-out;
              }
              &:hover {
                text-decoration: none;
                color: $black;
                &:after {
                  margin-left: 10px;
                }
              }
            }

            &:before {
              content: "";
              clear: both;
              display: block;
              background: url(../images/ex-arrow.png) top center no-repeat;
              background-size: auto;
              background-size: 100%;
              width: 25px;
              height: 25px;
              position: absolute;
              top: -11px;
              left: 68px;
            }
          }

          &:hover {
            .info-content {
              opacity: 1;
              visibility: visible;
            }
          }
        }
      }
    }
  }

  &:after {
    content: "";
    display: block;
    background: url(../images/banner-shape.png) top center no-repeat;
    background-size: 100%;
    width: 662px;
    height: 552px;
    position: absolute;
    top: 15%;
    right: 0;
  }
}

@media (max-width: 1660px) {
}

@media (max-width: 1440px) {
  .banner-with-form {
    .dis-flex {
      .hire-form {
        flex-basis: 41%;
      }
    }
  }
}

@media (max-width: 1366px) {
  .banner-with-form {
    .dis-flex {
      .hire-form {
        flex-basis: 45%;
        &:before {
          display: none;
        }

        .form-wrap {
          .mid-sec {
            padding: 20px 20px;
            .button-section {
              margin: 20px 0 0;
              .btn-div {
                .white-btn {
                  min-width: 170px;
                }
              }
            }
          }

          h3 {
            font-size: 24px;
            line-height: 40px;
          }
          .bottom-sec {
            padding: 20px 20px;
          }
        }
      }
    }

    &:after {
      width: 616px;
      height: 500px;
    }
  }
}

@media (max-width: 1080px) {
  .banner-with-form {
    padding: 100px 0;
    .dis-flex {
      .hire-form {
        .form-wrap {
          .top-sec{
            &:before{width: 100%;}
          }
          .mid-sec {
            .button-section {
              .btn-div {
                .white-btn {
                  min-width: auto;
                }
              }
            }
          }
          .bottom-sec {
            padding: 20px 20px;
            .frm-list {
              ul {
                li {
                  padding: 0 20px;
                  margin: 0 5px;
                }
              }
            }
          }
        }
      }
    }

    &:after {
      width: 530px;
      height: 400px;
    }
  }
}

@media (max-width: 991px) {
  .banner-with-form {
    padding: 90px 0 60px;
    .breadcrumbs {
      top: 50px;
    }
    .dis-flex {
      padding: 60px 0 0;
      .hire-content {
        width: 100%;
        h1 {
          margin: 0 0 15px;
        }
      }
      .hire-form {
        flex-basis: 100%;
        margin: 60px 0 0;
        .form-wrap {
          .top-sec {
            img {
              margin-top: -45px;
              height: 248px;
            }
          }
        }
      }
    }

    &:after {
      display: none;
    }
  }
}

@media (max-width: 767px) {
  .banner-with-form {
    padding-bottom: 40px;
    padding-top: 80px;
    .breadcrumbs {
      top: 60px;
    }
    .dis-flex {
      padding: 70px 0 0;
      .hire-content {
        p {
          margin: 0 0 15px;
          font-size: 16px;
          line-height: 27px;
        }
        ul {
          li {
            font-size: 16px;
            margin: 0 0 8px;
            padding-left: 18px;
            &:before {
              top: 10px;
              width: 7px;
              height: 7px;
            }
          }
        }
      }
      .hire-form {
        .form-wrap {
          border-radius: 20px;
          p {
            font-size: 16px;
          }

          .mid-sec {
            .button-section {
              .btn-div {
                flex-basis: 100%;
                .white-btn {
                  min-width: 200px;
                }
              }
              .devide {
                width: 100%;
                text-align: center;
                padding: 5px;
                &:before {
                  width: 16px;
                  height: 1px;
                  display: inline-block;
                  position: initial;
                  margin-right: 5px;
                  vertical-align: middle;
                }
                &:after {
                  width: 16px;
                  height: 1px;
                  display: inline-block;
                  position: initial;
                  margin-left: 5px;
                  vertical-align: middle;
                }
              }
            }
          }

          .bottom-sec {
            padding: 10px 20px 20px;
            .frm-list {
              ul {
                li {
                  line-height: 1.3;
                  font-size: 11px;
                  padding: 0 10px 0 18px;
                  font-size: 11px;
                  margin: 0 4px;
                  &:before {
                    top: 0px;
                  }
                  &:after {
                    width: calc(100% - 40px);
                    height: 1px;
                    left: 20px;
                  }

                  &.process {
                    &:before {
                      top: 1px;
                    }
                    .info {
                      width: 280px;
                      padding: 10px;
                      bottom: -130px;
                      z-index: 999;
                      h4 {
                        font-size: 12px;
                        margin: 0 0 4px;
                        &:before {
                          width: 20px;
                          height: 20px;
                          top: -23px;
                          right: 25px;
                        }
                      }
                      p {
                        font-size: 10px;
                        line-height: 26px;
                        color: $black;
                        line-height: 16px;
                      }
                    }
                  }
                }
              }
            }
          }
        }

        .info-wrap {
          .info {
            .info-content {
              width: 196px;
              top: 22px;
              left: -73px;
              text-align: center;
              h4 {
                line-height: 20px;
              }
            }
          }
        }
      }
    }
  }
}
